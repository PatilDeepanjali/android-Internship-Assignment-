<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#F7F7F7"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="18dp">

        <!-- Left Icon -->

        <LinearLayout
            android:id="@+id/iconContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_recent_icon"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgType"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_group"/>
        </LinearLayout>

        <!-- Title -->

        <TextView
            android:id="@+id/tvSplitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iconContainer"
            android:layout_marginStart="18dp"
            android:layout_marginTop="6dp"
            android:text="Team Dinner"
            android:textColor="#16233D"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <!-- Amount -->

        <TextView
            android:id="@+id/tvSplitAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvSplitTitle"
            android:layout_toEndOf="@id/iconContainer"
            android:layout_marginStart="18dp"
            android:layout_marginTop="4dp"
            android:text="Total payment $3900"
            android:textColor="#6D7280"
            android:textSize="13sp"/>

        <!-- Members -->

        <RelativeLayout
            android:id="@+id/memberLayout"
            android:layout_width="90dp"
            android:layout_height="42dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/member1"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/avatar1"
                app:civ_border_width="1dp"
                app:civ_border_color="#FFFFFF"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/member2"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/avatar2"
                app:civ_border_width="1dp"
                app:civ_border_color="#FFFFFF"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/member3"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="40dp"
                android:src="@drawable/avatar3"
                app:civ_border_width="1dp"
                app:civ_border_color="#FFFFFF"/>

        </RelativeLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>