<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_background"
        android:orientation="vertical">

        <!-- Top Header Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:background="#0058BE"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:text="Hi, Tushaar"
                    android:textColor="#DDEEFF"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:text="Split Your Bill"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Circular Avatar with image -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="20dp"
                android:contentDescription="@string/user_avatar"
                android:scaleType="centerCrop"
                android:src="@drawable/user"
                app:civ_border_color="#FFFFFF"
                app:civ_border_width="2dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0000"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="44dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Bill Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="6dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="182dp"
                    android:padding="20dp">

                    <!-- Split With -->
                    <TextView
                        android:id="@+id/txtSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Split with"
                        android:textColor="#4A4A4A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- Total Bill -->
                    <TextView
                        android:id="@+id/txtBillTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Bill"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- Amount -->
                    <TextView
                        android:id="@+id/tvTotalBill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$877.22"
                        android:textColor="#0A2342"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txtBillTitle"/>

                    <!-- Avatar Group -->
                    <RelativeLayout
                        android:id="@+id/avatarLayout"
                        android:layout_width="160dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txtSplit">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:contentDescription="@string/friend_avatar"
                            android:scaleType="centerCrop"
                            android:src="@drawable/avatar1"
                            app:civ_border_color="#FFFFFF"
                            app:civ_border_width="2dp"/>

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="26dp"
                            android:contentDescription="@string/friend_avatar"
                            android:scaleType="centerCrop"
                            android:src="@drawable/avatar2"
                            app:civ_border_color="#FFFFFF"
                            app:civ_border_width="2dp"/>

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="52dp"
                            android:contentDescription="@string/friend_avatar"
                            android:scaleType="centerCrop"
                            android:src="@drawable/avatar3"
                            app:civ_border_color="#FFFFFF"
                            app:civ_border_width="2dp"/>

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="78dp"
                            android:background="@drawable/bg_add_circle"
                            android:gravity="center"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"/>
                    </RelativeLayout>

                    <!-- Split Button -->
                    <Button
                        android:id="@+id/btnSplitNow"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_button_blue"
                        android:text="Split Now"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/imgFood"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <!-- Food Image -->
                    <ImageView
                        android:id="@+id/imgFood"
                        android:layout_width="78dp"
                        android:layout_height="78dp"
                        android:contentDescription="@string/food_image"
                        android:padding="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/food"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ── SCROLLABLE BODY ── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="70dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_margin="20dp"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Nearby friends -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nearby Friends"
                        android:textColor="#0D1B3D"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSeeAllFriends"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#0C5BD9"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Horizontal Friends -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="20dp"
                        android:layout_marginLeft="20dp"
                        android:orientation="horizontal">

                        <!-- Friend 1 -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:contentDescription="@string/friend_avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar1"
                                app:civ_border_color="#7AA7E8"
                                app:civ_border_width="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Fox"
                                android:textColor="#4D4D4D"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <!-- Friend 2 -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:contentDescription="@string/friend_avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar2"
                                app:civ_border_color="#7AA7E8"
                                app:civ_border_width="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Hope"
                                android:textColor="#4D4D4D"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <!-- Friend 3 -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:contentDescription="@string/friend_avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar3"
                                app:civ_border_color="#7AA7E8"
                                app:civ_border_width="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="John"
                                android:textColor="#4D4D4D"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <!-- Friend 4 -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:contentDescription="@string/friend_avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar4"
                                app:civ_border_color="#7AA7E8"
                                app:civ_border_width="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Smit"
                                android:textColor="#4D4D4D"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <!-- Friend 5 -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:contentDescription="@string/friend_avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar4"
                                app:civ_border_color="#7AA7E8"
                                app:civ_border_width="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Smit"
                                android:textColor="#4D4D4D"
                                android:textSize="13sp"/>
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Recent Split Heading -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:layout_margin="20dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Split"
                        android:textColor="#172B4D"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Recycler view -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentSplits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:elevation="8dp"
        app:itemIconTint="@drawable/bottom_nav_color_state"
        app:itemTextColor="@drawable/bottom_nav_color_state"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>